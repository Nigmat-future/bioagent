@article{PMC2013,
  author  = {(PubMed / Europe PMC)},
  title   = {; 3,281 tumors across 12 cancer types) established TP53 as the dominant significantly mutated gene pan-cancer, altered in virtually 100% of high-grade serous ovarian cancers, ~96% of basal-like breast cancers, ~86% of squamous cell lung cancers, and ~75% of colorectal cancers, yet mutated in only ~5–10% of kidney clear cell and thyroid cancers—underscoring striking cancer-type-specific variation. The TCGA Pan-Cancer integrated analysis (PMID: 31365877) further revealed that TP53-mutated tumors display systematically enhanced expression of cell cycle progression genes and proteins (CCND1, CDK4/6, MYC) across cancer types, mechanistically explaining the aggressive phenotypes associated with p53 loss. The canonical tumor suppressor functions—transcriptional activation of CDKN1A (p21), BAX, PUMA, NOXA; induction of apoptosis, senescence, cell cycle arrest, and DNA repair—are abolished by the vast majority of missense mutations, which cluster in the DNA-binding domain at six major hotspot residues: R175H, G245S, R248Q, R248W, R249S, and R273H/C (PMID: 29099487; PMID: 36859359)},
  journal = {Nature},
  year    = {2013},
  doi     = {10.1038/nature12634},
  pmid    = {24132290},
}

@article{PMC2023,
  author  = {(PubMed / Europe PMC)},
  title   = {; PMID: 33932560). CpG methylation-dependent deamination (C→T transitions at CpG dinucleotides) accounts for ~25% of all TP53 mutations, explaining many hotspot codons. UV-induced CC→TT tandem mutations drive TP53 alterations in cutaneous cancers, while tobacco-specific nitrosamines generate G→T transversions enriched in lung adenocarcinomas (particularly at codon 249 in hepatocellular carcinoma exposed to aflatoxin B1). Beyond loss-of-function (LoF), a critical subset of missense mutations confer **gain-of-function (GoF)** oncogenic properties—particularly R175H, R248W, R248Q, R249S, and R273H—through mechanisms including binding to and inactivating p63/p73 family members, co-opting chromatin regulators (MLL1, MLL2, MOZ methyltransferases leading to global H3K4me3/H3K27ac elevation; PMID: 26331536), activating oncogenic transcription programs, and suppressing innate immune signaling including STING and cGAS pathways to promote immune evasion (PMID: 33545063). The dominant-negative (DN) mechanism—whereby mutant p53 tetramers inactivate residual wild-type p53 protein—has been shown to drive selection pressure specifically for missense mutations over truncating nonsense or frameshift variants in myeloid malignancies (PMID: 31395785). The distinction between mono-allelic vs. bi-allelic TP53 alteration has profound clinical consequences: biallelic inactivation (mutation + loss of heterozygosity, or two separate mutations) is associated with dramatically worse outcomes in myelodysplastic syndromes and resistance to hypomethylating agents, as comprehensively documented in a large prospective cohort (PMID: 32747829)},
  journal = {Signal Transduct Target Ther},
  year    = {2023},
  doi     = {10.1038/s41392-023-01347-1},
  pmid    = {36859359},
}

@article{PMC2017,
  author  = {(PubMed / Europe PMC)},
  title   = {; PMID: 27166782). In the context of KRAS-mutant lung adenocarcinoma, TP53 co-mutations engage a distinct biology from STK11 co-mutations, with TP53 co-mutations generally retaining immunotherapy responsiveness while STK11 mutations confer resistance (PMID: 29773717; PMID: 31406302). Therapeutic targeting of mutant p53 has remained an elusive goal for decades. Strategies include: (1) MDM2/MDM4 inhibitors (idasanutlin, siremadlin, navtemadlin) for TP53 wild-type tumors (active clinical trials including NCT05180695); (2) mutant p53 reactivation by APR-246/eprenetapopt (PRIMA-1Met), which converts mutant p53 to a wild-type-like conformation through covalent modification of C277 and C238; (3) degraders of mutant p53 protein; (4) synthetic lethal approaches exploiting vulnerabilities created by p53 loss (PMID: 36216888; PMID: 34583722; PMID: 36672377). Despite initial phase II promise in AML/MDS, APR-246 failed its phase III endpoint, highlighting the complexity of patient stratification by mutation subtype and the need for better biomarkers of response. Computational tools such as CHASMplus (PMID: 31202631) and saturation genome editing combined with multiplexed functional assays (PMID: 34793697) are enabling systematic reclassification of the thousands of TP53 variants of uncertain significance (VUS) in clinical databases. The newly described Panorama database (PMID: 41540913) represents a step toward standardized oncogenic evaluation of somatic variants pan-cancer},
  journal = {Cell},
  year    = {2017},
  doi     = {10.1016/j.cell.2017.08.028},
  pmid    = {28886379},
}


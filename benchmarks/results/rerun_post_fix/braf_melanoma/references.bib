@article{PMC2013,
  author  = {(PubMed / Europe PMC)},
  title   = {). Beyond the cell-autonomous tumor, BRAF-mutant melanomas also exploit the tumor microenvironment (TME): stromal cell secretion of hepatocyte growth factor (HGF) activates the MET receptor, reactivating both MAPK and PI3K-AKT pathways to confer innate resistance to RAF inhibitors even before drug selection pressure is applied (PMID: 22763439). Pathway enrichment analysis confirms that the BRAF-melanoma gene network (including NRAS, PTEN, PIK3CA, AKT1, CDKN2A, NF1, MITF, MET, EGFR, RAC1, IGF1R) maps overwhelmingly onto KEGG Melanoma (p=2.49×10⁻²⁷) and EGFR-TKI resistance pathways (p=9.23×10⁻²⁴), revealing mechanistic parallels with cross-cancer resistance biology},
  journal = {Cancer Cell},
  year    = {2013},
  doi     = {10.1016/j.ccr.2013.02.003},
  pmid    = {23477830},
}

@article{PMC2010,
  author  = {(PubMed / Europe PMC)},
  title   = {): among 32 patients with BRAF V600E metastatic melanoma at the recommended dose (960 mg BID), 26 patients (81%) achieved objective responses with a median progression-free survival of ~6 months. However, resistance invariably develops, and numerous mechanisms have been characterized. Acquired resistance through aberrant BRAF splicing is particularly well-defined: p61BRAF(V600E), a 61-kDa splice variant lacking exons 4–8 (which encode the RAS-binding domain), dimerizes constitutively in a RAS-independent fashion, restoring ERK signaling despite RAF inhibitor binding — detected in 6/19 (32%) of patients with vemurafenib-acquired resistance (PMID: 22113612). Additional resistance routes include gain-of-function NRAS or MEK1/2 mutations, COT1/MAP3K8 amplification, upregulation of receptor tyrosine kinases (EGFR, PDGFRB, IGF1R), and PTEN loss driving PI3K-AKT activation (which also impairs T-cell immunotherapy efficacy, PMID: 26645196). The combinatorial approach — dabrafenib (BRAF inhibitor) plus trametinib (MEK inhibitor) in a Phase 1/2 trial (n=247, PMID: 23020132) — significantly improved median PFS to 9.4 months versus 5.8 months for dabrafenib monotherapy, and reduced cutaneous squamous cell carcinoma rates (7% vs 19%), validating vertical MAPK pathway blockade as superior. Emerging triple-combination approaches (BRAF+MEK+ERK inhibitors) and next-generation RAF dimer inhibitors (e.g., PHI-501, which also targets DDR1/2; PMID: 41935307) aim to tackle residual MAPK reactivation. Exploiting ERK hyperactivation-induced toxicity — where paradoxical ERK signaling above a threshold kills cancer cells — is also attracting computational modeling interest (PMID: 41865130)},
  journal = {N Engl J Med},
  year    = {2010},
  doi     = {10.1056/nejmoa1002011},
  pmid    = {20818844},
}

@article{PMC2016,
  author  = {(PubMed / Europe PMC)},
  title   = {) have revealed profound cellular heterogeneity in the melanoma TME and identified distinct resistance-associated cell states, particularly the MITF-high (proliferative) ↔ MITF-low (invasive/mesenchymal) phenotypic switching axis, which underpins drug-tolerant persister populations. Recent work on cell state plasticity driven by tissue-specific inflammation (PMID: 41920996) and stochastic phenotypic switching (ArXiv: 2001.07690) highlight that non-genetic resistance is as important as mutational resistance, yet remains computationally underexplored. A decade of checkpoint immunotherapy experience (PMID: 35241833) confirms that understanding the molecular basis of immune sensitivity — including microsatellite instability, tumor mutational burden, and TME composition — will guide rational combinations of targeted and immunotherapy strategies},
  journal = {Science},
  year    = {2016},
  doi     = {10.1126/science.aad0501},
  pmid    = {27124452},
}

